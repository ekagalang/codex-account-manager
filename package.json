{
  "author": {
    "name": "ekagalang",
    "email": "ekagalangpratama@gmail.com",
    "url": "https://ekagalang.my.id"
  },
  "name": "codex-account-manager",
  "version": "1.1.2",
  "description": "Switch Codex CLI accounts instantly",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --port 2301",
    "electron": "wait-on http://localhost:2301 && cross-env NODE_ENV=development DEV_PORT=2301 electron .",
    "start": "concurrently \"npm run dev\" \"npm run electron\"",
    "build:vite": "vite build",
    "build:electron": "tsc -p tsconfig.node.json",
    "build": "npm run build:electron && npm run build:vite",
    "dist": "npm run build && electron-builder --config electron-builder.config.js",
    "dist:win": "npm run build && electron-builder --config electron-builder.config.js --win",
    "dist:mac": "npm run build && electron-builder --config electron-builder.config.js --mac",
    "dist:linux": "npm run build && electron-builder --config electron-builder.config.js --linux"
  },
  "dependencies": {
    "electron-store": "^10.0.1",
    "electron-updater": "^6.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "smol-toml": "^1.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electronmon": "^2.0.3",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.2.0",
    "vite-plugin-electron": "^0.28.8",
    "wait-on": "^9.0.5"
  }
}
