{
  "name": "codex-account-manager",
  "version": "1.0.0",
  "description": "Switch Codex CLI accounts instantly",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite --port 5174",
    "electron": "wait-on http://localhost:5174 && cross-env NODE_ENV=development DEV_PORT=5174 electron .",
    "start": "concurrently \"npm run dev\" \"npm run electron\"",
    "build": "tsc -p tsconfig.node.json && vite build",
    "dist": "npm run build && electron-builder"
},
  "dependencies": {
    "electron-store": "^10.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "smol-toml": "^1.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electronmon": "^2.0.3",
    "tailwindcss": "^4.1.0",
    "typescript": "^5.7.0",
    "vite": "^6.2.0",
    "vite-plugin-electron": "^0.28.8",
    "wait-on": "^9.0.5"
  }
}
